#!/bin/sh
arg="$*"

filter() {
    which fzf > /dev/null 2>&1 \
        || (echo fzf not found; exit 1)
    # --bind 'enter:transform:echo print("$FZF_QUERY")+accept' \

    fzf --exact --tmux \
        --print-query \
        --bind "start:reload:findproj \"$arg\" || true" \
        --info-command '{ [ -z "$FZF_QUERY" ] || [ "$FZF_MATCH_COUNT" -gt 0 ]; } &&
        echo || echo "New Project: ~/Sync/$FZF_QUERY"'
}

which tmux > /dev/null 2>&1 \
    || (echo tmux not found; exit 1)

if ! selected="$(filter)"; then
    selected="$(printf '%s\n' "$selected" | tail -n 1)"

    if [ -n "$selected" ]; then
        selected="$HOME/Sync/$selected"
        mkdir -p "$selected"
    fi

    # undefined
else
    selected="$(printf '%s\n' "$selected" | tail -n +2)"
fi

# no selection, nothing to do
[ -z "$selected" ] && exit

selected="$(printf '%s\n' "$selected" | sed "s|^~|$HOME|")"

selected_name=$(basename "$selected" | tr . _)

# give subdirs a unique name
d="$(dirname "$selected")"
[ "$d" = ~/Sync ] || selected_name="$(basename "$d")/$selected_name"

# not in tmux session and tmux is not running
if [ -z "$TMUX" ] && ! pgrep -x tmux > /dev/null 2>&1; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit
fi

# -t="..."
#   ^ The equals sign in the "-t": target session argument usage below is VERY important,
#     it enforces exact matching on session names.
#
#     Otherwise, with whitepspace -t "..." the behavior is to partially match the session name.
#
#     See: https://github.com/tmux/tmux/issues/346
#          https://superuser.com/questions/1174750/tmux-has-session-search-is-prefix-matching

# tmux session already exists
tmux has-session -t="$selected_name" > /dev/null 2>&1 \
    || tmux new-session -d -s "$selected_name" -c "$selected"

# not in tmux session and tmux is running
[ -z "$TMUX" ] \
    && (tmux attach-session -t="$selected_name"; exit)

# inside tmux session
tmux switch-client -t="$selected_name"
