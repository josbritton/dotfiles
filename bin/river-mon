#!/bin/sh

for n in $(seq "$2" "$3"); do
    tags=$((1 << (n - $2)))
    echo "debug: \$1: $1, \$2: $2, \$3: $3, \$n: $n, \$tags: $tags" >&2

    riverctl map normal Super "$n" spawn \
	    "riverctl focus-output \"$1\" && riverctl set-focused-tags \"$tags\""
    riverctl map normal Super+Shift "$n" spawn \
	    "riverctl send-to-output \"$1\" && riverctl set-view-tags \"$tags\""
done

eww open-many waybar:"$1" \
    --arg "$1":monitor="$1" \
    --arg "$1":tags="[$(seq -s "," "$2" "$3")]"

eww get enable-activate-linux \
    | jq -ecM 'type == "number" and . > 0' >/dev/null 2>&1 \
    && eww open-many activate-linux:"egg-$1" \
        --arg "egg-$1":monitor="$1"
