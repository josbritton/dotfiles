output DP-3 {
    enable
    mode 2560x1440@165.000
    position 0,0
}
output DP-2 {
    enable
    mode 2560x1440@165.000
    position 2560,0
}

profile dual {
    output DP-3 enable
    output DP-2 enable
    exec WELLKNOWN_OUTPUTS=DP-3\ DP-2 ~/.config/river/user DP-3 DP-2
}

profile primary {
    output DP-3 enable
    exec WELLKNOWN_OUTPUTS=DP-3\ DP-2 ~/.config/river/user DP-3
}

profile secondary {
    output DP-2 enable
    exec WELLKNOWN_OUTPUTS=DP-3\ DP-2 ~/.config/river/user DP-2
}
