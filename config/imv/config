[options]
suppress_default_binds = true

[binds]
q = quit
<Left> = prev
<Right> = next
h = prev
l = next

x = close
f = fullscreen
d = overlay
p = exec echo $imv_current_file
c = center
s = scaling next
<Shift+S> = upscaling next
a = zoom actual
r = reset

<Shift+D> = exec gio trash "$imv_current_file"; close
