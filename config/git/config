[include]
    path = ~/.config/git/private
[user]
    useConfigOnly = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
    gpgsign = true
[init]
	defaultBranch = master
[pager]
	branch = false
[url "git@github-JosBritton:JosBritton"]
    insteadOf = git@github.com:josbritton
[includeIf "hasconfig:remote.*.url:git@github.com:josbritton/**"]
	path = ~/.config/git/user/JosBritton
[includeIf "hasconfig:remote.*.url:git@git.swifthomelab.net:josbritton/**"]
	path = ~/.config/git/user/JosBritton
[push]
    autoSetupRemote = true
[submodule]
    recurse = true
